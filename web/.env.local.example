# Copy to .env.local and fill in values.
# API_INTERNAL_URL is used by next.config.js to proxy /api/* calls to FastAPI.
# In Docker it's http://api:8000; in local dev it's http://localhost:8000.
API_INTERNAL_URL=http://localhost:8000

# Telegram bot username (without @) — shown in the Login Widget on /login.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=TTTask_bot

# Set to 1 to run the dashboard with no backend: MSW serves a snapshot of real
# data (web/public/seed.json) and the auth gate is bypassed. Leave unset/0 normally.
NEXT_PUBLIC_API_MOCK=0
