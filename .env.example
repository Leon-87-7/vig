# === Slice #1 (Scaffold) — required at startup ===

# Telegram
TELEGRAM_BOT_TOKEN=                  # Bot token from @BotFather
TELEGRAM_WEBHOOK_SECRET=             # Random string sent in X-Telegram-Bot-Api-Secret-Token header
WEBHOOK_URL=                         # Public HTTPS base, e.g. https://cortex-power-tripod.ngrok-free.dev

# Runtime
REDIS_URL=redis://redis:6379/0       # Inside Docker network; use redis://localhost:6379/0 from host
DB_PATH=/app/data/jobs.db            # SQLite database path inside container
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR

# === Slice #1 — optional (defaults work; downstream slices validate at runtime) ===

TELEGRAM_STICKER_GEMINI_FAIL=        # Sticker file_id for Gemini failure (forward sticker to @userinfobot)
TELEGRAM_STICKER_DRIVE_FAIL=         # Sticker file_id for Drive failure

# === Slices #2/#3 — frame & transcript sidecar (transcript_server.py on port 5151) ===

FRAME_SERVICE_URL=http://10.0.0.4:5151                       # LAN IP for sidecar (slice #2 short pipeline)
TRANSCRIPT_SERVICE_URL=http://host.docker.internal:5151      # Docker alias (slice #3/#4 long pipeline)

# === Slice #2 — Brave Search (short video link verification) ===

BRAVE_API_KEY=                       # Optional — Brave Search enhancement disabled if absent
ENABLE_BRAVE_SEARCH=true

JINA_API_KEY=                         # Optional — Jina enrichment disabled if absent

GEMINI_FREE_API_KEY=                 # AIzaSy... from https://aistudio.google.com/app/apikey
GEMINI_PAID_API_KEY=
GITHUB_TOKEN=                             # Optional — for Github repo enrichment — if absent, enrichment is skipped and the plain list is returned

# === Slices #2/#3 — Google APIs (Drive, Sheets) ===

GOOGLE_SERVICE_ACCOUNT_JSON=/app/credentials/service_account.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_SHORT=1CbD66mZHw-l0omyBlzpIo7h07AL66ORh
GOOGLE_DRIVE_FOLDER_LONG=17Qtch1zqks273Z2a5t5e4WlQlQR_oi-B
GOOGLE_SHEETS_ID_SHORT=1KlcBexPgn7GAWkStKxqyzfwuSrrOq6QUXtvza4AS124
GOOGLE_SHEETS_ID_LONG=1_dbaViGITC0FzFLwr-9oiLC9OFATJcnsUMtKH9gDqQA

# === Slice #4 — Gemini Text enrichment (free key → paid key fallback) ===

# === Slice #5 — Second Brain ===

GOOGLE_DRIVE_FOLDER_BRAIN=
GEMINI_EMBEDDING_MODEL=text-embedding-004
BRAIN_REFRESH_BATCH=50
BRAIN_MIN_SCORE=0.5

# === Slices #6/#7 — Mini-PRD feature ===

GOOGLE_DRIVE_FOLDER_PRD=
GOOGLE_SHEETS_ID_PRD=
PRD_MAX_TRANSCRIPT_CHARS=60000
PRD_INTENT_COOLDOWN_SECONDS=15
PRD_INCLUDE_FRAMES=false
PRD_AUTO_MODEL=gemini-2.5-flash
PRD_INTENT_MODEL=gemini-2.5-pro
