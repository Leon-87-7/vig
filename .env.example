
# === Slice #1 (Scaffold) — required at startup ===

# Telegram
TELEGRAM_BOT_TOKEN=
WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
OPERATOR_CHAT_ID=

# Runtime
REDIS_URL=       # Inside Docker network; use redis://localhost:6379/0 from host
DB_PATH=            # SQLite database path inside container
LOG_LEVEL=                       # DEBUG | INFO | WARNING | ERROR

# Cloudflare 
CLOUDFLARE_TUNNEL_TOKEN=
# Vercel
API_INTERNAL_URL=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# === Slice #1 — optional (defaults work; downstream slices validate at runtime) ===

TELEGRAM_STICKER_GEMINI_FAIL=      # Sticker file_id for Gemini failure (forward sticker to @userinfobot)
TELEGRAM_STICKER_DRIVE_FAIL=        # Sticker file_id for Drive failure (use a different sticker)

FRAME_SERVICE_URL=
TRANSCRIPT_SERVICE_URL=

# Base URL of the web dashboard, used to build "Open in Dashboard" links in
# Telegram job messages. Leave blank to omit the button. Production example:
# DASHBOARD_URL=https://app.leondev.xyz
DASHBOARD_URL=

# === API Keys ===

BRAVE_API_KEY=
ENABLE_BRAVE_SEARCH=

JINA_API_KEY=

GEMINI_API_KEY=
GEMINI_PAID_API_KEY=
GITHUB_TOKEN=

# === Slices #2/#3 — Google APIs (Drive, Sheets) ===

GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GOOGLE_OAUTH_REDIRECT_URI=         # Deployed callback URL registered on the OAuth client
GOOGLE_TOKEN_ENCRYPTION_KEY=       # Random secret encrypting per-user tokens at rest (e.g. `openssl rand -base64 32`); losing/changing it disconnects all users

GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_WEB_CLIENT_SECRET=

GOOGLE_STORAGE_BUCKET=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_JSON=

GOOGLE_DRIVE_FOLDER_SHORT=
GOOGLE_DRIVE_FOLDER_LONG=
GOOGLE_DRIVE_FOLDER_BRAIN=
GOOGLE_DRIVE_FOLDER_PRD=

GOOGLE_SHEETS_ID_SHORT=
GOOGLE_SHEETS_ID_LONG=
GOOGLE_SHEETS_ID_PRD=
GOOGLE_SHEETS_ID=


# === Second Brain ===

GEMINI_EMBEDDING_MODEL=
BRAIN_REFRESH_BATCH=50
BRAIN_MIN_SCORE=0.5

# === Mini-PRD feature ===

PRD_MAX_TRANSCRIPT_CHARS=60000
PRD_INTENT_COOLDOWN_SECONDS=15
PRD_INCLUDE_FRAMES=false
PRD_AUTO_MODEL=gemini-2.5-flash
PRD_INTENT_MODEL=gemini-2.5-pro

# === Ops bot (ADR-0036) ===
# Separate internal Telegram bot. Production URL example:
# OPS_WEBHOOK_URL=https://api.leondev.xyz/webhook/ops
OPS_BOT_TOKEN=
OPS_WEBHOOK_SECRET=
OPS_WEBHOOK_URL=
OPS_CHAT_IDS=
OPS_ADMIN_CHAT_IDS=
OPS_DEV_CHAT_IDS=
OPS_DEV_NOTIFICATIONS=false

# Local Ops callback E2E is explicit: start the API, expose port 8000 with ngrok,
# then set OPS_WEBHOOK_URL=https://<ngrok-host>/webhook/ops in .env.local.
# Uvicorn never starts ngrok automatically.
