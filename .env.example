# Telegram
TELEGRAM_BOT_TOKEN=                  # Bot token from @BotFather
WEBHOOK_URL=                         # Fixed ngrok URL, e.g. https://cortex-power-tripod.ngrok-free.dev
TELEGRAM_WEBHOOK_SECRET=             # Optional — recommended; set to any random string to verify webhook origin
TELEGRAM_STICKER_GEMINI_FAIL=        # Sticker file_id for Gemini failure (forward sticker to @userinfobot)
TELEGRAM_STICKER_DRIVE_FAIL=         # Sticker file_id for Drive failure (use a different sticker)

# Services
TRANSCRIPT_URL=http://host.docker.internal:5151   # Transcript server on host machine
BRAVE_API_KEY=                       # Optional — Brave Search enhancement disabled if absent

# Google
GEMINI_API_KEY=                      # Gemini API key from https://aistudio.google.com/app/apikey
GOOGLE_SERVICE_ACCOUNT_JSON=/app/credentials/service_account.json   # Path inside container (mounted volume)
GOOGLE_OAUTH_CLIENT_ID=              # OAuth 2.0 client ID (Desktop app) — for Drive uploads
GOOGLE_OAUTH_CLIENT_SECRET=          # OAuth 2.0 client secret
GOOGLE_OAUTH_REFRESH_TOKEN=          # Run get_token.py once to obtain this
GOOGLE_DRIVE_FOLDER_SHORT=1CbD66mZHw-l0omyBlzpIo7h07AL66ORh
GOOGLE_DRIVE_FOLDER_LONG=17Qtch1zqks273Z2a5t5e4WlQlQR_oi-B
GOOGLE_SHEETS_ID_SHORT=1KlcBexPgn7GAWkStKxqyzfwuSrrOq6QUXtvza4AS124
GOOGLE_SHEETS_ID_LONG=1_dbaViGITC0FzFLwr-9oiLC9OFATJcnsUMtKH9gDqQA

# App
DB_PATH=/app/data/jobs.db            # SQLite database path inside container
PORT=8000                            # FastAPI listen port
NUM_WORKERS=1                        # Number of concurrent pipeline workers
